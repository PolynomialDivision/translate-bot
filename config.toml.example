[matrix]
homeserver = "https://matrix.org"
# Bot account credentials — create a separate account for this bot
user_id = "@yourtranslatebot:matrix.org"
access_token = "YOUR_ACCESS_TOKEN"
# Optional: security key from Element's "Set up Secure Backup"
# Needed once to self-sign the bot's device (removes "not verified by owner" warning).
# Steps: log in as bot in Element Web → Settings → Security → Set up Secure Backup → generate key
# After first successful run showing "Cross-signing bootstrapped", remove this line.
recovery_key = "EsXX xxxx xxxx xxxx xxxx xxxx xxxx xxxx"
device_id = "YOUR_DEVICE_ID"

[libretranslate]
# Option A: official public instance (free API key required — sign up at libretranslate.com)
url = "https://libretranslate.com"
api_key = "YOUR_API_KEY"

# Option B: open mirrors (no API key needed)
# url = "https://translate.argosopentech.com"

# Option C: self-hosted (no API key needed by default)
# url = "http://your-unraid-ip:5000"

[translation]
# Languages to translate between (bot translates between these two)
langs = ["en", "de", "uk"]
# Minimum detection confidence to attempt translation (0.0–1.0)
min_confidence = 0.5
# Whether the translation references the original message at all (default: true).
# true  → translation is a reply (or thread reply) to the original message
# false → translation is posted as a standalone message, no relation
# reply_to_original = true
# When reply_to_original = true: use m.thread instead of m.in_reply_to (default: true).
# true  → m.thread relation (translation appears in the thread panel in Element/FluffyChat)
# false → m.in_reply_to relation (normal Matrix quote-reply)
# Has no effect when reply_to_original = false.
# thread_replies = true
# Send translations as m.notice instead of m.text (default: false).
# m.notice messages are rendered with muted styling in most clients and do not
# trigger push notifications, making them less intrusive for room members who
# are not the intended audience of the translation.
# silent_messages = false
# Maximum concurrent requests to LibreTranslate/ltengine across detection and
# translation. Lower this if the backend degrades under bursts.
# backend_concurrency = 4
# Retry and timeout policy for each Matrix message translation.
# request_timeout_secs bounds one backend request; overall_timeout_secs bounds
# the complete multi-target translation operation. If any required target still
# fails after this budget, the bot sends no partial translation.
# request_timeout_secs = 60
# max_attempts = 3
# retry_initial_backoff_ms = 250
# overall_timeout_secs = 90

# Optional per-room translation overrides. Keys are Matrix room IDs.
# Any omitted field inherits from [translation].
# [room_translations."!abcdef:matrix.org"]
# langs = ["en", "de"]
# min_confidence = 0.7
#
# [room_translations."!ghijkl:matrix.org"]
# langs = ["de", "uk"]
# silent_messages = true

[security]
# Users allowed to issue !reset-trust @user:server commands.
# Only these users can allow someone to re-verify after their first verification.
admin_users = ["@you:matrix.org"]

# Only these users may invite the bot to a room.
# If empty, the bot accepts invites from everyone (not recommended).
allowed_inviters = ["@you:matrix.org"]

# Which devices receive room keys. Options:
#   identity_based  — only devices cross-signed by their owner (default, recommended)
#   only_trusted    — only explicitly verified devices
#   all_devices     — all devices, no restriction
encryption_strategy = "identity_based"
